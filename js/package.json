{
  "name": "@lineagelabs/wayid-verify",
  "version": "0.1.0",
  "description": "Verify the WayID of an AI agent at your gateway.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wayid",
    "agent",
    "identity",
    "verification",
    "gateway",
    "ai-agents"
  ],
  "license": "MIT",
  "author": "Lineage Labs",
  "homepage": "https://github.com/LineageLabs/wayid-verify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LineageLabs/wayid-verify.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/LineageLabs/wayid-verify/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
